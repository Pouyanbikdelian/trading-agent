# Copy this file to `.env` and fill in. `.env` is gitignored.

# ---- Environment ----
# Either "research", "paper", or "live". Default is "research" — no broker calls.
TRADING_ENV=research

# ---- IBKR / IB Gateway connection ----
# Local TWS:         host=127.0.0.1  paper=7497 live=7496
# Local IB Gateway:  host=127.0.0.1  paper=4002 live=4001
# docker-compose:    host=ib-gateway paper=4002 live=4001  (set by compose, not here)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=17

# IBKR account login. Only needed inside docker-compose so the bundled
# IB Gateway can log in unattended. Local TWS reads these from its own UI.
IBKR_USERNAME=
IBKR_PASSWORD=
# 'paper' or 'live'. The IB Gateway image inside docker-compose reads this
# on boot; the trader container reads TRADING_ENV + ALLOW_LIVE_TRADING.
IBKR_TRADING_MODE=paper

# Hard guard: live trading must be explicitly enabled. Set to "true" ONLY when ready.
# The risk manager refuses to submit live orders unless this is true AND TRADING_ENV=live.
ALLOW_LIVE_TRADING=false

# ---- Data sources (all optional; yfinance + ccxt are free) ----
# Tiingo (paid intraday data, $10/mo) — leave empty to skip.
TIINGO_API_KEY=

# Polygon (paid intraday data) — leave empty to skip.
POLYGON_API_KEY=

# ---- Notifications (optional) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Storage ----
DATA_DIR=./data/parquet
LOG_DIR=./logs
STATE_DIR=./state

# ---- Risk limits (used by the risk manager; can also be overridden in config/risk.yaml) ----
MAX_GROSS_EXPOSURE=1.0       # 1.0 = 100% of equity, no leverage
MAX_POSITION_PCT=0.10        # any single name capped at 10% of equity
MAX_DAILY_LOSS_PCT=0.02      # daily loss > 2% triggers kill switch for the day
MAX_DRAWDOWN_PCT=0.15        # 15% peak-to-trough drawdown halts the system

# ---- docker-compose runner defaults (only read by docker-compose.yml) ----
# Local CLI uses --strategy / --cron flags; these only matter inside a
# container that launches its own `trading paper run` from compose.
UNIVERSE=sp500
STRATEGY=top_k_momentum
# Default: 4:05pm ET on Friday (after-close, weekly) for quarterly-rebalance
# strategies. Adjust to your strategy's natural cadence.
CRON=5 21 * * FRI
TZ=UTC
