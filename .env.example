# Copy this file to `.env` and fill in. `.env` is gitignored.

# ---- Environment ----
# Either "research", "paper", or "live". Default is "research" — no broker calls.
TRADING_ENV=research

# ---- IBKR / IB Gateway connection ----
# Local TWS:         host=127.0.0.1  paper=7497 live=7496
# Local IB Gateway:  host=127.0.0.1  paper=4002 live=4001
# docker-compose:    host=ib-gateway paper=4002 live=4001  (set by compose, not here)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=17

# IBKR account login. Only needed inside docker-compose so the bundled
# IB Gateway can log in unattended. Local TWS reads these from its own UI.
IBKR_USERNAME=
IBKR_PASSWORD=
# 'paper' or 'live'. The IB Gateway image inside docker-compose reads this
# on boot; the trader container reads TRADING_ENV + ALLOW_LIVE_TRADING.
IBKR_TRADING_MODE=paper

# Hard guard: live trading must be explicitly enabled. Set to "true" ONLY when ready.
# The risk manager refuses to submit live orders unless this is true AND TRADING_ENV=live.
ALLOW_LIVE_TRADING=false

# ---- Data sources (all optional; yfinance + ccxt are free) ----
# Tiingo (paid intraday data, $10/mo) — leave empty to skip.
TIINGO_API_KEY=

# Polygon (paid intraday data) — leave empty to skip.
POLYGON_API_KEY=

# ---- LLM agent committee (optional; advisory only) ----
# Enable the daily multi-agent committee (docs/concept_multiagent_memory.md).
# Requires ONE of the API keys below. Costs ~$5-30/mo depending on model.
AGENTS_ENABLED=false
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Model override (default: a mid-tier model per provider)
AGENTS_MODEL=

# ---- Committee cadence & Sentinel (optional; defaults shown) ----
# The committee is EXPENSIVE (multi-voice LLM debate). It convenes from
# exactly three places and nowhere else: the schedule below, the late-day
# de-risk trigger below, and manual /committee. Times are NYSE
# (America/New_York) so they track the US session across DST.
#
# Scheduled committee: twice weekly, mid-session (default Mon & Fri 13:00 ET).
# AGENTS_COMMITTEE_CRON=0 13 * * MON,FRI
#
# Late-day de-risk: one check ~50 min before the close (default 15:10 ET). If
# a held name is down >= SENTINEL_DERISK_DROP_PCT on the day by then, the
# committee convenes ONCE. The noisy open is excluded; nothing fires post-close.
# SENTINEL_DERISK_CRON=10 15 * * MON-FRI
# SENTINEL_DERISK_DROP_PCT=10.0
#
# The intraday Sentinel is INFORMATION ONLY (never convenes the committee):
# it sends a caution ping at most every ALERT_DEBOUNCE_HOURS while the tripped
# set is unchanged; a new/worse name pings immediately (ESCALATION_STEP_PCT).
# SENTINEL_ALERT_DEBOUNCE_HOURS=2.0
# SENTINEL_ESCALATION_STEP_PCT=3.0

# ---- Dashboard (optional) ----
# Web dashboard at http://<vps>:8787 — REQUIRED password (basic auth).
DASHBOARD_USER=yan
DASHBOARD_PASS=

# ---- Notifications (optional) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Storage ----
DATA_DIR=./data/parquet
LOG_DIR=./logs
STATE_DIR=./state

# ---- Risk limits (used by the risk manager; can also be overridden in config/risk.yaml) ----
MAX_GROSS_EXPOSURE=1.0       # 1.0 = 100% of equity, no leverage
MAX_POSITION_PCT=0.10        # any single name capped at 10% of equity
MAX_DAILY_LOSS_PCT=0.02      # daily loss > 2% triggers kill switch for the day
MAX_DRAWDOWN_PCT=0.15        # 15% peak-to-trough drawdown halts the system
# Margin policy. 0.0 = cash-account behavior: any order that would push
# a currency cash balance below zero is rejected pre-submit. For a CHF
# base account buying USD stocks, this means you must FX-convert into
# USD first (use /fx 100000 CHF to USD). Set to e.g. 0.50 if you want
# to permit up to 50% of equity in margin debt. LIVE-RECOMMENDED: 0.0.
MAX_MARGIN_BORROWING_PCT=0.0

# ---- Cycle approval workflow ----
# When true, every cycle pauses after computing the basket and asks the
# operator via Telegram before submitting orders. Operator replies with
# /approve, /approve <N>, /approve flat, or /reject. Default off for
# research/paper; flip on for live. The cycle times out and auto-rejects
# after CYCLE_APPROVAL_TIMEOUT_S seconds if no reply arrives.
REQUIRE_CYCLE_APPROVAL=false
CYCLE_APPROVAL_TIMEOUT_S=600

# ---- docker-compose runner defaults (only read by docker-compose.yml) ----
# Local CLI uses --strategy / --cron flags; these only matter inside a
# container that launches its own `trading paper run` from compose.
UNIVERSE=sp500
STRATEGY=top_k_momentum
# Default: 4:05pm ET on Friday (after-close, weekly) for quarterly-rebalance
# strategies. Adjust to your strategy's natural cadence.
CRON=5 21 * * FRI
TZ=UTC

# Host's docker group GID — the trader needs this to write to
# /var/run/docker.sock and restart the ib-gateway container when the
# broker session goes dead. Find yours with:
#   stat -c %g /var/run/docker.sock
# Defaults to 999 (Debian). Ubuntu is usually 998. Set explicitly if
# yours differs, otherwise the self-heal will EACCES on the socket.
DOCKER_GID=999
